{
  "name": "zotnfoundclone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.0",
  "scripts": {
    "build": "next build",
    "dev": "node scripts/run-dev.ts local",
    "dev:staging": "node scripts/run-dev.ts staging",
    "dev:prod": "node scripts/run-dev.ts prod",
    "format": "npx prettier --write .",
    "lint": "npx oxlint",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "format:check": "npx prettier --check .",
    "drizzle:generate": "npx drizzle-kit generate",
    "drizzle:migrate": "npx drizzle-kit migrate",
    "drizzle:studio": "npx drizzle-kit studio",
    "check:env:dev": "node scripts/validate-stage-env.ts dev",
    "check:env:dev:prod-target": "node scripts/validate-stage-env.ts dev production",
    "check:env:prod": "node scripts/validate-stage-env.ts production",
    "deploy:dev": "DEPLOY_ENV_TARGET=production npm run check:env:dev:prod-target && npx sst deploy --stage dev",
    "deploy:prod": "npm run check:env:prod && npx sst deploy --stage production"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1012.0",
    "@aws-sdk/client-sns": "^3.1012.0",
    "@next/bundle-analyzer": "16.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/render": "^2.0.4",
    "@types/aws-lambda": "^8.10.161",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "aws-lambda": "^1.0.7",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-auth": "^1.5.5",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.575.0",
    "next": "16.2.0",
    "oxlint-tsgolint": "^0.17.0",
    "pg": "^8.20.0",
    "posthog-js": "^1.362.0",
    "posthog-node": "^5.28.4",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "resend": "^6.9.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "aws-cdk-lib": "^2.243.0",
    "constructs": "^10.5.1",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "sst": "^3.19.3",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
